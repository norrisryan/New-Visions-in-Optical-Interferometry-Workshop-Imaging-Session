#!/bin/bash
set -e

echo "=== Installing OITOOLS and dependencies ==="
julia -e '
using Pkg
Pkg.add("OIFITS")
Pkg.add(url="https://github.com/emmt/ArrayTools.jl.git")
Pkg.add(url="https://github.com/emmt/LazyAlgebra.jl.git")
Pkg.add(url="https://github.com/emmt/OptimPackNextGen.jl.git")
Pkg.add(url="https://github.com/fabienbaron/OITOOLS.jl.git")
Pkg.add(["PyCall", "PyPlot", "Statistics"])
'

echo "=== Precompiling ==="
julia -e 'using OITOOLS; println("OITOOLS loaded OK")'
echo "=== postBuild complete ==="

